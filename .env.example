# DeepSeek API (required for dialogue)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_URL=https://api.deepseek.com

# Optional: Ollama for local embeddings (LanceDB memory)
OLLAMA_HOST=http://localhost:11434
ARIS_EMBED_MODEL=nomic-embed-text

# Optional: data directory override
# ARIS_DATA_DIR=/path/to/aris/data
